# ─────────────────────────────────────
# Discourse Forum
# ─────────────────────────────────────
DISCOURSE_URL=https://forum.heatpunks.org
# Optional: Only needed if forum requires authentication
DISCOURSE_API_KEY=
DISCOURSE_API_USERNAME=

# ─────────────────────────────────────
# Email (Brevo SMTP)
# ─────────────────────────────────────
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=   # Your Brevo account login email
SMTP_PASS=   # Brevo SMTP key (Brevo dashboard → SMTP & API → SMTP tab → Generate key)

# ─────────────────────────────────────
# Umami Analytics
# ─────────────────────────────────────
NEXT_PUBLIC_UMAMI_WEBSITE_ID=
NEXT_PUBLIC_UMAMI_URL=

# ─────────────────────────────────────
# Site Configuration
# ─────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://heatpunks.org
